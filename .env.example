# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://fegg_user:fegg_password@localhost:5432/fegg_jaay

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Claude API (Anthropic) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp 360dialog ───────────────────────────────────────────────────────
# Ces valeurs sont par boutique (stockées en DB), pas globales.
# La clé ci-dessous sert uniquement à valider la signature HMAC du webhook Meta.
WA_WEBHOOK_VERIFY_TOKEN=mon_token_de_verification_ngrok
WA_APP_SECRET=mon_app_secret_meta

# ─── OpenAI Whisper ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=mon_cloud_name
CLOUDINARY_API_KEY=mon_api_key
CLOUDINARY_API_SECRET=mon_api_secret

# ─── Timezone / Locale ────────────────────────────────────────────────────────
TIME_ZONE=Africa/Dakar
